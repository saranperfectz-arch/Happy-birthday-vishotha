<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy Birthday Vishotha ❤️</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
overflow:hidden;
background:linear-gradient(135deg,#ff4d88,#ff9fc7);
height:100vh;
display:flex;
justify-content:center;
align-items:center;
text-align:center;
color:white;
}

#home,#birthday{
position:absolute;
width:100%;
height:100%;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
}

#birthday{
display:none;
}

h1{
font-size:55px;
text-shadow:0 0 15px white;
animation:zoom 2s infinite alternate;
}

@keyframes zoom{
from{transform:scale(1);}
to{transform:scale(1.08);}
}

button{

margin-top:40px;
padding:18px 40px;
border:none;
border-radius:40px;
font-size:20px;
font-weight:bold;
background:white;
color:#ff2d7a;
cursor:pointer;

}

#slide{

width:260px;
height:350px;
border-radius:20px;
margin-top:30px;
object-fit:cover;
box-shadow:0 0 20px white;

}

#message{

font-size:22px;
margin-top:25px;
padding:20px;
line-height:35px;

}

audio{
display:none;
}

</style>

</head>

<body>

<div id="home">

<h1>Happy ❤️</h1>

<button onclick="startSurprise()">
🎁 Surprise
</button>

</div>

<div id="birthday">

<h1>
🎉 Happy Birthday Vishotha 🎉
</h1>

<img id="slide" src="photo1.jpg">

<div id="message">

May your smile always shine... ❤️

</div>

<audio id="song" loop>

<source src="song.mp3" type="audio/mpeg">

</audio>

</div>
<script>

const photos=[
"photo1.jpg",
"photo2.jpg",
"photo3.jpg"
];

let current=0;

function startSurprise(){

document.getElementById("home").style.display="none";
document.getElementById("birthday").style.display="flex";

document.getElementById("song").play();

setInterval(nextPhoto,3000);

createHearts();

}

function nextPhoto(){

current++;

if(current>=photos.length){

current=0;

}

document.getElementById("slide").src=photos[current];

}

function createHearts(){

setInterval(()=>{

let heart=document.createElement("div");

heart.innerHTML="❤️";

heart.style.position="fixed";

heart.style.left=Math.random()*100+"vw";

heart.style.top="100vh";

heart.style.fontSize=(20+Math.random()*25)+"px";

heart.style.animation="floatUp 6s linear forwards";

document.body.appendChild(heart);

setTimeout(()=>{

heart.remove();

},6000);

},300);

}

let style=document.createElement("style");

style.innerHTML=`

@keyframes floatUp{

0%{

transform:translateY(0);

opacity:1;

}

100%{

transform:translateY(-120vh);

opacity:0;

}

}

`;

document.head.appendChild(style);

</script>

</body>
</html>
